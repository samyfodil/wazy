(component
  (core module $m (memory (export "mem") 1))
  (core instance $i (instantiate $m))
  (alias core export $i "mem" (core memory $mem))
  (type $st (stream u8))
  (type $ft (future u32))
  (canon backpressure.inc (core func $bpi))
  (canon backpressure.dec (core func $bpd))
  (canon task.return (result u32) (core func $tr))
  (canon task.cancel (core func $tc))
  (canon subtask.drop (core func $sd))
  (canon subtask.cancel (core func $sc))
  (canon waitable-set.new (core func $wsn))
  (canon waitable-set.wait (memory $mem) (core func $wsw))
  (canon waitable-set.poll (memory $mem) (core func $wsp))
  (canon waitable-set.drop (core func $wsd))
  (canon waitable.join (core func $wj))
  (canon stream.new $st (core func $sn))
  (canon stream.read $st (core func $sr))
  (canon stream.write $st (core func $sw))
  (canon stream.drop-readable $st (core func $sdr))
  (canon stream.drop-writable $st (core func $sdw))
  (canon future.new $ft (core func $fn))
  (canon future.read $ft (core func $fr))
  (canon future.write $ft (core func $fw))
  (canon error-context.new (memory $mem) (core func $ecn))
  (canon error-context.debug-message (memory $mem) (core func $ecdm))
  (canon error-context.drop (core func $ecd))
  (canon context.get i32 0 (core func $cg))
  (canon context.set i32 0 (core func $cs))
)
